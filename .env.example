GITHUB_TOKEN=ghp_your_github_token_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
HOST=127.0.0.1
PORT=3000
REQUEST_TIMEOUT_MS=45000
BUILD_TIMEOUT_MS=1200000
TEST_TIMEOUT_MS=1200000
MIN_STARS=200
REPO_LIMIT=10
REPO_CONCURRENCY=2
PR_LIMIT=10
SCAN_MODE=issue-first
TARGET_REPO=
MERGED_AFTER=
DRY_RUN=true
DB_PATH=./data/repo-miner.db
OUTPUT_ROOT=./output
WORK_ROOT=~/repo-issue-miner-work
SETUP_CLONE_ROOT=~/Documents/pr-writer-tasks
CODEX_CLI_PATH=
